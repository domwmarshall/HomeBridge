{
  "expo": {
    "name": "HomeBridge",
    "slug": "homebridge-coparenting",
    "scheme": "homebridge",
    "version": "0.8.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F6F1"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "HomeBridge uses your photos so parents can identify belongings and medical items.",
          "cameraPermission": "HomeBridge uses the camera to photograph belongings and medical items."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#176B65",
          "defaultChannel": "homebridge-reminders"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uk.homebridge.coparenting"
    },
    "android": {
      "package": "uk.homebridge.coparenting",
      "adaptiveIcon": {
        "backgroundColor": "#F7F6F1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 12,
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
